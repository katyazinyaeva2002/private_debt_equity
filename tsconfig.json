{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "node20",
    "target": "es2023",
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "exclude": [
    "node_modules",
    "artifacts",
    "cache",
    "typechain-types",
    "dist"
  ]
}